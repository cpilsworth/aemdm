{
  "name": "aemdm",
  "version": "0.2.2",
  "description": "CLI for Adobe Dynamic Media with OpenAPI",
  "license": "Apache-2.0",
  "author": "Chris Pilsworth",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cpilsworth/aemdm.git"
  },
  "homepage": "https://github.com/cpilsworth/aemdm#readme",
  "bugs": {
    "url": "https://github.com/cpilsworth/aemdm/issues"
  },
  "keywords": [
    "aem",
    "adobe",
    "dynamic-media",
    "cli",
    "openapi"
  ],
  "type": "module",
  "bin": {
    "aemdm": "dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --enable-source-maps src/cli.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "pack:check": "npm pack --dry-run --cache .npm-cache",
    "prepack": "npm run build",
    "prepublishOnly": "npm run test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.9.1",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.0.7"
  }
}
